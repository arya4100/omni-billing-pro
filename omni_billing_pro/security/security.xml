<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Groups -->
    <record id="group_omni_billing_user" model="res.groups">
        <field name="name">OmniBilling / User</field>
        <field name="category_id" ref="base.module_category_accounting_localizations"/>
    </record>

    <record id="group_omni_billing_manager" model="res.groups">
        <field name="name">OmniBilling / Manager</field>
        <field name="category_id" ref="base.module_category_accounting_localizations"/>
        <field name="implied_ids" eval="[(4, ref('omni_billing_pro.group_omni_billing_user'))]"/>
    </record>
</odoo>
